# Copie para .env e ajuste se necessário:  cp .env.example .env

# Porta do gateway (endpoint único de todos os serviços)
LOCALSTACK_PORT=4566

# Faixa de portas externas dos serviços
LOCALSTACK_EXTERNAL=4510-4559

# Serviços a habilitar (separados por vírgula)
LOCALSTACK_SERVICES=sqs,sns,s3

# Região AWS padrão
AWS_REGION=us-east-1

# Persistir dados entre reinícios (1 = sim, 0 = não)
LOCALSTACK_PERSISTENCE=1

# Log detalhado (1 = sim, 0 = não)
LOCALSTACK_DEBUG=0

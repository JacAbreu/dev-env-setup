# Variáveis de configuração do Hadoop lidas pela imagem apache/hadoop.
# Cada linha vira uma propriedade nos *-site.xml correspondentes.

CORE-SITE.XML_fs.defaultFS=hdfs://namenode:9000
CORE-SITE.XML_hadoop.http.staticuser.user=root

HDFS-SITE.XML_dfs.replication=1
HDFS-SITE.XML_dfs.namenode.rpc-address=namenode:9000
HDFS-SITE.XML_dfs.namenode.http-address=0.0.0.0:9870
HDFS-SITE.XML_dfs.datanode.address=0.0.0.0:9866
HDFS-SITE.XML_dfs.datanode.http.address=0.0.0.0:9864
HDFS-SITE.XML_dfs.permissions.enabled=false

# Copie para .env e ajuste se necessário:  cp .env.example .env
# Valores abaixo são os mesmos defaults usados no docker-compose.yml.

# Postgres
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=dev
POSTGRES_PORT=5432

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=dev
MYSQL_USER=dev
MYSQL_PASSWORD=dev
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# MongoDB
MONGO_USER=dev
MONGO_PASSWORD=dev
MONGO_PORT=27017
